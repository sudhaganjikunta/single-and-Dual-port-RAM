module single_port_ram #(parameter data_width =32,
                         parameter depth = 16,
                         parameter addr_width = 4 )
                         (input clk,
                         input [addr_width-1:0]address,
                         input [data_width-1:0] data_in,
                         input write_en,
                         input read_en,
                         output [data_width-1:0]data_out);
 reg [data_width-1:0] tmp_data;
 reg [data_width-1:0] memory [depth-1:0];   //reg[31:0] mem[15:0]
 
 always @(posedge clk)begin
 if(write_en)  
 memory[address] <=data_in;  //to access 16 different locations
 else if (read_en)
 tmp_data<=memory[address];
 end
 assign data_out=tmp_data;    
endmodule
